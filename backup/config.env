# OMNI-ANCHOR Backup Configuration
# Sourced by backup.sh, validate.sh, and restore scripts

# ── Local storage ─────────────────────────────────────────────────────────────
LOCAL_BACKUP_ROOT="/root/backups/omni-anchor"
KEEP_DAILY=7          # daily backups to retain
KEEP_WEEKLY=4         # weekly backups to retain (kept on Sunday)

# ── Encryption ────────────────────────────────────────────────────────────────
BACKUP_KEY_FILE="/root/.backup-key"

# ── Offsite (rclone) ──────────────────────────────────────────────────────────
# Set RCLONE_REMOTE to enable offsite sync. Leave blank to skip.
# Example: "r2:omni-anchor-backups" or "b2:bucket/omni-anchor"
# Run: rclone config  →  add remote named "omni-backup"
RCLONE_REMOTE="gdrive:"  # Google Drive — root_folder_id set in rclone.conf points to omni-anchor-backups
RCLONE_FLAGS="--transfers=4 --retries=3 --fast-list"

# ── Telegram alerts ───────────────────────────────────────────────────────────
TG_TOKEN="8853756715:AAGdKmfAyPHnO9o1Dt6zeogAS__byMVlqt8"
TG_CHAT="7794812292"

# ── Paths ─────────────────────────────────────────────────────────────────────
OMNI_ROOT="/root/omni-anchor"
WIDGET_ROOT="/var/www/widget"
HERMES_HOME="/root/.hermes"
LETSENCRYPT_DIR="/etc/letsencrypt"
DASHCLAW_ROOT="/root/dashclaw"
SYSTEMD_SYSTEM="/etc/systemd/system"
SYSTEMD_USER="/root/.config/systemd/user"
